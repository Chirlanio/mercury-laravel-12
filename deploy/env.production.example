# Mercury SaaS - Production Environment

APP_NAME=Mercury
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://mercury.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning

# Central Database (master - tenants, plans, billing)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mercury_central
DB_USERNAME=mercury_app
DB_PASSWORD=

# Multi-Tenancy
CENTRAL_DOMAINS=mercury.com.br
TENANCY_DB_PREFIX=mercury_

# Session (scoped per subdomain)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=.mercury.com.br

# Cache & Queue
CACHE_STORE=database
QUEUE_CONNECTION=database

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@mercury.com.br
MAIL_FROM_NAME="${APP_NAME}"

# Filesystem
FILESYSTEM_DISK=local

# Vite
VITE_APP_NAME="${APP_NAME}"
